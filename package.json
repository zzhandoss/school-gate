{
  "name": "school-gate",
  "private": true,
  "version": "1.2.0",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm exec concurrently -n api,device-service,bot,workers,admin-ui -c blue,green,magenta,yellow,cyan \"pnpm --filter @school-gate/api dev\" \"pnpm dev:device-service\" \"pnpm --filter @school-gate/bot dev\" \"pnpm dev:workers\" \"pnpm --filter admin-ui dev\"",
    "lint": "eslint \"apps/**/*.ts\" \"packages/**/*.ts\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/.output/**\" --ignore-pattern \"**/node_modules/**\" --ignore-pattern \"data/**\"",
    "lint:fix": "eslint \"apps/**/*.ts\" \"packages/**/*.ts\" --fix --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/.output/**\" --ignore-pattern \"**/node_modules/**\" --ignore-pattern \"data/**\"",
    "typecheck": "pnpm -r --if-present --filter ./packages/** --filter ./apps/** run typecheck",
    "test": "vitest",
    "test:local": "vitest",
    "build": "pnpm run build:packages && pnpm run build:apps",
    "build:packages": "pnpm -r --if-present --filter ./packages/** run build",
    "build:packages:watch": "pnpm -r --if-present --filter ./packages/** run build:watch",
    "dev:packages": "pnpm run build:packages:watch",
    "build:apps": "pnpm -r --if-present --filter ./apps/** run build",
    "build:apps:watch": "pnpm -r --if-present --filter ./apps/** run build:watch",
    "predb:generate": "pnpm --filter @school-gate/db run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "device:db:generate": "drizzle-kit generate --config=drizzle.device.config.ts",
    "device:db:migrate": "drizzle-kit migrate --config=drizzle.device.config.ts",
    "dev:workers": "pnpm --filter @school-gate/worker dev:all",
    "start:workers": "pnpm --filter @school-gate/worker start:all",
    "dev:device-service": "pnpm --filter @school-gate/device-service dev:all",
    "start:device-service": "pnpm --filter @school-gate/device-service start:all",
    "adapter:mock:dev": "pnpm --filter @school-gate/adapter-mock dev",
    "retention:worker": "pnpm exec tsx apps/worker/src/retention/main.ts",
    "retention:run-once": "pnpm exec tsx apps/worker/src/retention/runOnce.ts",
    "retention:schedule:apply": "pnpm exec tsx apps/worker/src/retention/applySchedule.ts",
    "retention:schedule:remove": "pnpm exec tsx apps/worker/src/retention/removeSchedule.ts",
    "backup:create": "node packages/ops/dist/cli.js create",
    "backup:verify": "node packages/ops/dist/cli.js verify",
    "backup:prune": "node packages/ops/dist/cli.js prune",
    "backup:restore": "node packages/ops/dist/cli.js restore",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "packageManager": "pnpm@10.20.0",
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "pino": "^10.3.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
