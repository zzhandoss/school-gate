{
  "name": "@school-gate/infra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "@school-gate/core": "workspace:*",
    "@school-gate/config": "workspace:*",
    "@school-gate/db": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
